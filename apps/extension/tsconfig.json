{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "jsx": "react-jsx",
        "strict": true,
        "skipLibCheck": true,
        "noEmit": true,
        "isolatedModules": true,
        "resolveJsonModule": true,
        "baseUrl": ".",
        "paths": { "@/*": ["src/*"] },
        "ignoreDeprecations": "6.0",
        "types": ["chrome", "vite/client"]
    },
    "include": ["src/**/*.ts", "src/**/*.tsx", "vite.config.ts", "manifest.config.ts"]
}
