# Copy to .env.local (Vite). For local Supabase: `supabase start` then `supabase status`.

VITE_SUPABASE_URL=http://127.0.0.1:54321
# Publishable key (dashboard/API settings). Same role as the legacy "anon" JWT.
VITE_SUPABASE_PUBLISHABLE_KEY=
# Secret key bypasses RLS — use only in server scripts, Edge Functions, etc. Never prefix with VITE_.
SUPABASE_SECRET_KEY=

# Google OAuth (local Supabase): Web client in Google Cloud; in supabase/config.toml set
# [auth.external.google] enabled = true. Authorized redirect URI in Google Cloud:
#   http://127.0.0.1:54321/auth/v1/callback
# Supabase CLI loads `.env` for config.toml env() (not always .env.local). Use `.env` for these two,
# and keep VITE_* in `.env.local` if you prefer.
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
