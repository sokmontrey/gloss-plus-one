SB_AUTH_GOOGLE_CLIENT_ID=
SB_AUTH_GOOGLE_SECRET=

GOOGLE_OAUTH_REDIRECT_TO=http://localhost:3000/api/auth/google/callback
# OAuth success: browser redirect with tokens in URL fragment (#...), not query string.
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:5173/

# Comma-separated, explicit origins only (no *). With credentials enabled, use your real app and extension origins, e.g. chrome-extension://YOUR_EXTENSION_ID
CORS_ORIGINS=http://localhost:5173

SUPABASE_URL=http://127.0.0.1:54321
# Anon/publishable — API auth adapter uses this for OAuth, getUser, refresh.
SUPABASE_PUBLISHABLE_KEY=
# Service role — server only (auth session revoke via admin API). Profile CRUD uses publishable key + user JWT (RLS). Never ship to clients.
SUPABASE_SECRET_KEY=
SUPABASE_JWT_SECRET=

PORT=3000
