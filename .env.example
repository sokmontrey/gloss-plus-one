# ── Local dev setup ────────────────────────────────────────────────────────────
#
# 1. Copy this file to .env and fill in the values below.
#
# 2. Start local Supabase:
#      supabase start
#
# 3. Build the extension and load it unpacked in Chrome:
#      npm run dev
#      chrome://extensions → Load unpacked → select dist/
#
# 4. Get the two URLs you need to register:
#      npm run ext:redirect-url
#
#    Then register them:
#      a) supabase/config.toml  →  additional_redirect_urls
#            https://<ext-id>.chromiumapp.org/
#      b) Google Cloud Console  →  OAuth 2.0 → Authorized redirect URIs
#            http://127.0.0.1:54321/auth/v1/callback
#
# 5. Restart Supabase to pick up the new config:
#      supabase stop && supabase start
#
# ───────────────────────────────────────────────────────────────────────────────

# Vite / extension (run: supabase status to get these)
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_PUBLISHABLE_KEY=

# Replacement pipeline: Edge Function `replace-pipeline` (supabase/functions/replace-pipeline).
# Served at {VITE_SUPABASE_URL}/functions/v1/replace-pipeline — same anon key headers as REST.
#
# Hosted: mirror these with `supabase secrets set KEY=value` (CLI) or Dashboard → Functions → Secrets.
# Local Edge: `supabase functions serve replace-pipeline --env-file .env` (or project root `.env` if your CLI setup loads it).

# MLM recoverability service base URL. POST path defaults to `/score`; override with RECOVERABILITY_SCORE_PATH.
# Leave empty → pipeline uses PIPELINE_CONTEXT_STUB only.
# Example (MLM on host, Edge in Docker): http://host.docker.internal:8000
RECOVERABILITY_API_URL=
# Request body shape: `spans` (default, V1 schema) or `words` (legacy `{ words[] }` scorer).
# Use `words` until the backend accepts schema_version 1 (see recoverability_contract.ts in replace-pipeline).
RECOVERABILITY_REQUEST_FORMAT=spans
RECOVERABILITY_SCORE_PATH=/score
# Force stub lane even when URL set: true | false
RECOVERABILITY_DISABLED=false
RECOVERABILITY_TIMEOUT_MS=120000
# Optional JSON: {"window_tokens":128,"stride_tokens":64,"batch_size":64}
RECOVERABILITY_SCORE_CONFIG_JSON=

# Deprecated aliases (still read if new keys unset): REPLACEABILITY_API_URL, REPLACEABILITY_DISABLED,
# REPLACEABILITY_TIMEOUT_MS, REPLACEABILITY_SCORE_CONFIG_JSON

REPLACE_THRESHOLD=
# Overrides REPLACE_THRESHOLD for that language code (ISO 639-1), e.g. REPLACE_THRESHOLD_FR=0.4
REPLACE_THRESHOLD_FR=

PIPELINE_TRANSLATION_FACTOR=1
PIPELINE_CONTEXT_STUB=1

PRESET_WEIGHT_CONTENT=0.65
PRESET_WEIGHT_FUNCTIONAL=0.35

# Loaded by the Supabase CLI for config.toml env() substitution.
# Create credentials at: https://console.cloud.google.com/apis/credentials
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# Server-side only — bypasses RLS. Never prefix with VITE_.
SUPABASE_SECRET_KEY=
