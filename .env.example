APP_URL=http://127.0.0.1:3000
API_URL=http://127.0.0.1:4000
PORT=4000

# Optional for extension cookie/CORS flow:
# EXTENSION_ORIGIN=chrome-extension://<your-extension-id>

SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=<sb_publishable_key>
SUPABASE_SERVICE_ROLE_KEY=<sb_service_role_key>

SESSION_COOKIE_NAME=gpo.sid
SESSION_COOKIE_SECRET=replace_with_a_random_secret_at_least_16_chars

PROFILE_TABLE=profiles
OAUTH_TEMP_TTL_SECONDS=600
ACCESS_TOKEN_REFRESH_SKEW_SECONDS=60

# Google OAuth credentials are consumed by Supabase auth config (local CLI setup):
SB_AUTH_GOOGLE_CLIENT_ID=<google_client_id>
SB_AUTH_GOOGLE_SECRET=<google_client_secret>
