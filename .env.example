# Copy to `.env`. Quick local path: `supabase start` · `npm run dev` · load `dist/` in Chrome ·
# `npm run ext:redirect-url` → add URL to `config.toml` additional_redirect_urls + GCP OAuth redirects.

# ── Extension (Vite) — `supabase status` for URLs
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_PUBLISHABLE_KEY=

# ── Edge Function: replace-pipeline (`supabase/functions/replace-pipeline`)
# Invoked at {VITE_SUPABASE_URL}/functions/v1/replace-pipeline (same anon key as REST).
# Deploy: `supabase secrets set KEY=value` · Local: `supabase functions serve replace-pipeline --env-file .env`
# Replace cutoff: DB `user_progressions.min_combined_confidence` (NULL → default 0.42 in code, see replace_threshold.ts)

PIPELINE_TRANSLATION_FACTOR=1
PIPELINE_CONTEXT_STUB=1

PRESET_WEIGHT_CONTENT=0.65
PRESET_WEIGHT_FUNCTIONAL=0.35

# ── Recoverability scorer (separate HTTP service; optional)
# Empty RECOVERABILITY_API_URL → stub lane only (PIPELINE_CONTEXT_STUB). Implement the API against:
#   supabase/functions/replace-pipeline/lib/recoverability_contract.ts
RECOVERABILITY_API_URL=
RECOVERABILITY_SCORE_PATH=/score
# spans = V1 JSON body (default) · words = legacy `{ words: string[] }` until your new backend matches V1
RECOVERABILITY_REQUEST_FORMAT=spans
RECOVERABILITY_DISABLED=false
RECOVERABILITY_TIMEOUT_MS=120000
# Optional: {"window_tokens":128,"stride_tokens":64,"batch_size":64}
RECOVERABILITY_SCORE_CONFIG_JSON=
# Aliases still honored if RECOVERABILITY_* unset: REPLACEABILITY_API_URL, REPLACEABILITY_DISABLED, …

# ── Supabase CLI (config.toml env substitution)
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
# Server-side only; never `VITE_`
SUPABASE_SECRET_KEY=
