{
  "setup-worktree-unix": [
    "npm ci",
    "if [ -f \"$ROOT_WORKTREE_PATH/.env\" ]; then cp \"$ROOT_WORKTREE_PATH/.env\" .env; fi",
    "if [ -f \"$ROOT_WORKTREE_PATH/.env.local\" ]; then cp \"$ROOT_WORKTREE_PATH/.env.local\" .env.local; fi"
  ],
  "setup-worktree-windows": [
    "npm ci",
    "if exist \"%ROOT_WORKTREE_PATH%\\\\.env\" copy \"%ROOT_WORKTREE_PATH%\\\\.env\" .env",
    "if exist \"%ROOT_WORKTREE_PATH%\\\\.env.local\" copy \"%ROOT_WORKTREE_PATH%\\\\.env.local\" .env.local"
  ],
  "setup-worktree": [
    "npm ci"
  ]
}
